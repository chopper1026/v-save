{
  "name": "vsave-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo run:android",
    "reset:native": "node ./scripts/reset-generated-native-projects.js",
    "strip:ios-push-entitlement": "node ./scripts/strip-ios-push-entitlement.js",
    "ios": "npm run strip:ios-push-entitlement && expo run:ios --device",
    "prebuild": "npm run reset:native && expo prebuild && npm run strip:ios-push-entitlement",
    "test": "tsx --test",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "release": "npm run strip:ios-push-entitlement && expo run:ios --device --configuration Release"
  },
  "dependencies": {
    "@backpackapp-io/react-native-toast": "^0.15.1",
    "@expo/vector-icons": "^15.0.2",
    "axios": "^1.13.6",
    "expo": "~55.0.6",
    "expo-clipboard": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-media-library": "~55.0.9",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-share-intent": "^6.0.0",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-video": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.11",
    "patch-package": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
